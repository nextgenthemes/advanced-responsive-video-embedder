{
	"name": "nextgenthemes/advanced-responsive-video-embedder",
	"description": "ARVE Advanced Responsive Video Embedder",
	"type": "wordpress-plugin",
	"license": "GPL-3.0",
	"authors": [
		{
			"name": "Nicolas Jonas",
			"homepage": "https://nextgenthemes.com",
			"role": "Developer"
		}
	],
	"require": {
		"php": ">=7.4",
		"nextgenthemes/wp-settings": "@dev",
		"automattic/jetpack-autoloader": "^v5.0.2"
	},
	"autoload": {
		"psr-4": {
			"Nextgenthemes\\ARVE\\": "php/"
		}
	},
	"extra": {
		"easy-digital-downloads/edd-sl-sdk": "^1.0.3",
		"release-repo-changes": {
			"nextgenthemes/wp-settings": {
				"type": "vcs",
				"url": "https://github.com/nextgenthemes/wp-settings.git"
			}
		}
	},
	"config": {
		"allow-plugins": {
			"automattic/jetpack-autoloader": true
		},
		"optimize-autoloader": true,
		"platform": {
			"php": "7.4"
		}
	},
	"repositories": {
		"nextgenthemes/wp-settings": {
			"type": "path",
			"url": "../wp-settings",
			"options": {
				"symlink": true
			}
		},
		"edd-sl-sdk": {
			"type": "vcs",
			"url": "git@github.com:awesomemotive/edd-sl-sdk.git"
		}
	}
}
